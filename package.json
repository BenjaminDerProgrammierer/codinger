{
  "name": "codinger",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db-migrate && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db": "docker-compose -f prisma/docker-compose.yml up",
    "db-studio": "prisma studio",
    "db-migrate": "prisma migrate dev && prisma generate",
    "db-apply-lessons": "tsx ./scripts/db-apply-lessons.ts",
    "prepush-checks": "npm run lint && npm run format && npm run typecheck && pnpm run build && pnpm run db-apply-lessons"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "emmet-monaco-es": "^5.7.0",
    "lucide-react": "^1.23.0",
    "mdast-util-directive": "^3.1.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
